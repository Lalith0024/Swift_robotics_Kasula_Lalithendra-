# Zenserp API Key - SERP Search
ZENSERP_API_KEY=your_zenserp_api_key_here

# App Configuration
# SQLite is a local file-based database. It will automatically create 'econwatch.db' in your backend folder.
# You don't need to install or run a separate database server!
DATABASE_URL=sqlite:///./econwatch.db

# How often the background worker should fetch new data
POLLING_INTERVAL_MINUTES=15
