# LLM API Keys (Provide at least one)
# Anthropic API Key (Claude) - Preferred
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Groq API Key (Llama 3.1 8B) - Free Fallback
GROQ_API_KEY=your_groq_api_key_here

# News Data Sources (Provide at least one)
# NewsAPI.org - Free Dev Tier
NEWSAPI_KEY=your_newsapi_key_here

# GNews.io - Free Tier (100 req/day)
GNEWS_API_KEY=your_gnews_api_key_here

# FRED (Federal Reserve Economic Data) API - Free
FRED_API_KEY=your_fred_api_key_here

# Zenserp API Key - SERP Search
ZENSERP_API_KEY=

# App Configuration
DATABASE_URL=sqlite:///./econwatch.db
POLLING_INTERVAL_MINUTES=15
